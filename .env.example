# Copy this file to .env and fill in your actual local values

# Server
BIND_ADDR=0.0.0.0:3000

# Database (change password for production)
DATABASE_URL=postgres://zorbs:zorbs_dev@localhost:5432/zorbs

# Upload directory
UPLOAD_DIR=uploads

# oAuth Login
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
# Get from https://github.com/settings/applications/new
# Callback URL: http://localhost:3000/auth/github/callback
# (use https://zorbs.io/... for prod)
