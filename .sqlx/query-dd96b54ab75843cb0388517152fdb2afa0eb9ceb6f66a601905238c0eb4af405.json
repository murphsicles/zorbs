  "query": "\n        INSERT INTO users (github_id, username, email, avatar_url)\n        VALUES ($1, $2, $3, $4)\n        ON CONFLICT (github_id) DO UPDATE SET\n            username = EXCLUDED.username,\n            email = EXCLUDED.email,\n            avatar_url = EXCLUDED.avatar_url,\n            updated_at = NOW()\n        RETURNING *\n        ",
